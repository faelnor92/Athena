# =========================================================================
# CONFIGURATION DE L'ESSAIM MULTI-AGENT JARVIS v2 (modèle d'exemple)
# -------------------------------------------------------------------------
# Copiez ce fichier en `.env` et renseignez vos valeurs.
# Le fichier `.env` est ignoré par git : n'y mettez JAMAIS de vraie clé
# dans `.env.example`. Aucune valeur réelle ne doit être committée.
# =========================================================================

# -------------------------------------------------------------------------
# 1. SÉCURITÉ & ACCÈS
# -------------------------------------------------------------------------
# Mot de passe d'administration de l'interface web.
# OBLIGATOIRE si le serveur est exposé (bind sur 0.0.0.0) : sans lui, le
# serveur refuse désormais de démarrer en mode exposé.
ADMIN_PASSWORD=

# Origines CORS autorisées (séparées par des virgules). Vide = défaut du code.
# Exemple : https://jarvis.mondomaine.fr,http://localhost:8000
ALLOWED_ORIGINS=

# Interface et port d'écoute du serveur.
# HOST=0.0.0.0 (défaut) = exposé réseau → ADMIN_PASSWORD devient OBLIGATOIRE.
# HOST=127.0.0.1 = accès local uniquement (auth optionnelle).
# En production, exposez via un reverse-proxy HTTPS, pas le port 8000 en clair.
HOST=0.0.0.0
PORT=8000

# Autoriser sudo/su dans l'exécuteur de commandes (DANGEREUX sur un VPS).
# Laisser "False" sauf besoin explicite.
ALLOW_SUDO_ON_VPS=False

# -------------------------------------------------------------------------
# 2. CHEMINS / STOCKAGE
# -------------------------------------------------------------------------
# Chemin du fichier de conversations persistantes.
# Vide = `conversations.json` à la racine du projet.
CONVERSATIONS_PATH=

# Boucle d'auto-amélioration : après une tâche non triviale, l'agent archive un
# court retour d'expérience en mémoire (resservi via le RAG). "true" (défaut) | "false".
SELF_IMPROVE=true

# Nb max d'outils/sous-agents exécutés EN PARALLÈLE dans un même tour
# (ex: plusieurs query_agent). 1 = exécution séquentielle. Défaut 4.
SWARM_MAX_PARALLEL=4

# --- Garde-fous d'exécution -------------------------------------------------
# Retries sur erreur LLM transitoire (backoff exponentiel). Défaut 2.
LLM_MAX_RETRIES=2
# Budget temps mur par run, en secondes (0 = illimité). Utile pour la latence vocale.
SWARM_MAX_SECONDS=0
# Budget tokens cumulés par run (0 = illimité).
SWARM_MAX_TOKENS=0

# Chemin du fichier de configuration des serveurs MCP.
# Vide = `mcp_servers.json` à la racine du projet.
MCP_CONFIG_PATH=

# --- Observabilité ----------------------------------------------------------
# Niveau de log (DEBUG/INFO/WARNING/ERROR) et dossier des logs (rotation auto).
LOG_LEVEL=INFO
LOG_DIR=logs
# Base SQLite de persistance des runs (inspection/rejeu).
RUNS_DB_PATH=runs.sqlite3

# Dossier de travail actif des agents (sandbox de fichiers).
# Vide = répertoire courant du process.
ACTIVE_WORKSPACE_DIR=

# --- Sandbox d'exécution de code/commandes ---------------------------------
# SANDBOX_MODE : "docker" (défaut, exécution isolée en conteneur jetable)
#                "off"    (exécution locale NON isolée, droits du serveur — risque assumé)
SANDBOX_MODE=docker
# Image de base du conteneur (doit être disponible/pullable).
SANDBOX_DOCKER_IMAGE=python:3.11-slim
SANDBOX_MEM_LIMIT=256m
SANDBOX_CPUS=1.0
SANDBOX_PIDS_LIMIT=128

# -------------------------------------------------------------------------
# 3. CLÉS D'API LLM (utilisées par LiteLLM selon les modèles d'agents.yaml)
# -------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GOOGLE_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
# Alibaba Dashscope / Qwen Cloud
DASHSCOPE_API_KEY=
QWEN_API_KEY=

# -------------------------------------------------------------------------
# 4. SERVEURS LLM LOCAUX & ENDPOINTS CUSTOM (OpenAI-compatible)
# -------------------------------------------------------------------------
# Ollama (ex: ollama/llama3)
OLLAMA_API_BASE=
# vLLM / LM Studio / llama.cpp / Open WebUI ...
CUSTOM_LLM_API_BASE=
CUSTOM_LLM_API_KEY=

# -------------------------------------------------------------------------
# 5. GÉNÉRATION D'IMAGES & VIDÉOS
# -------------------------------------------------------------------------
IMAGE_GENERATOR_PROVIDER=
VIDEO_GENERATOR_PROVIDER=
CUSTOM_IMAGE_API_BASE=
CUSTOM_IMAGE_API_KEY=
CUSTOM_VIDEO_API_BASE=
CUSTOM_VIDEO_API_KEY=
FAL_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# -------------------------------------------------------------------------
# 6. EXÉCUTION DISTANTE SSH (optionnel)
# -------------------------------------------------------------------------
SSH_HOST=
SSH_PORT=22
SSH_USERNAME=
# Préférez une clé à un mot de passe.
SSH_PASSWORD=
SSH_KEY_PATH=
SSH_REMOTE_CWD=
# Fichier known_hosts dédié (optionnel ; le known_hosts système est chargé par défaut).
SSH_KNOWN_HOSTS=
# Ajouter automatiquement les clés d'hôte inconnues (DANGEREUX, vulnérable au MITM).
# Laisser "False" : par défaut un hôte inconnu est REFUSÉ. Mettre "True" uniquement
# pour un premier raccordement contrôlé, puis repasser à False.
SSH_AUTO_ADD_HOST_KEYS=False

# -------------------------------------------------------------------------
# 7. DOMOTIQUE HOME ASSISTANT (optionnel)
# -------------------------------------------------------------------------
HA_URL=
HA_TOKEN=

# -------------------------------------------------------------------------
# 8. AGENDA / CALENDRIER (optionnel)
# -------------------------------------------------------------------------
CALDAV_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=
GOOGLE_CALENDAR_ID=
EXTERNAL_ICAL_URL=

# -------------------------------------------------------------------------
# 9. MESSAGERIE BOT (optionnel)
# -------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

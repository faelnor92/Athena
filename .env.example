# =========================================================================
# CONFIGURATION DE L'ESSAIM MULTI-AGENT JARVIS v2 (modèle d'exemple)
# -------------------------------------------------------------------------
# Copiez ce fichier en `.env` et renseignez vos valeurs.
# Le fichier `.env` est ignoré par git : n'y mettez JAMAIS de vraie clé
# dans `.env.example`. Aucune valeur réelle ne doit être committée.
# =========================================================================

# -------------------------------------------------------------------------
# 0. IDENTITÉ DE L'APPLICATION
# -------------------------------------------------------------------------
# Nom affiché dans l'interface (titre d'onglet + logo). Change-le pour rebrander
# l'application sans toucher au code. (L'agent orchestrateur reste nommé en interne ;
# pour renommer son affichage, édite son display_name dans agents.yaml.)
APP_NAME=Jarvis

# -------------------------------------------------------------------------
# 1. SÉCURITÉ & ACCÈS
# -------------------------------------------------------------------------
# Mot de passe d'administration de l'interface web.
# OBLIGATOIRE si le serveur est exposé (bind sur 0.0.0.0) : sans lui, le
# serveur refuse désormais de démarrer en mode exposé.
ADMIN_PASSWORD=
# Multi-utilisateur : dès qu'un compte existe (créé via ⚙️ Réglages → Utilisateurs),
# la connexion par identifiant devient obligatoire. ADMIN_PASSWORD reste un admin
# de secours. Chemin du fichier de comptes (hash PBKDF2, jamais committé) :
USERS_PATH=

# Origines CORS autorisées (séparées par des virgules). Vide = défaut du code.
# Exemple : https://jarvis.mondomaine.fr,http://localhost:8000
ALLOWED_ORIGINS=

# Interface et port d'écoute du serveur.
# HOST=0.0.0.0 (défaut) = exposé réseau → ADMIN_PASSWORD devient OBLIGATOIRE.
# HOST=127.0.0.1 = accès local uniquement (auth optionnelle).
# En production, exposez via un reverse-proxy HTTPS, pas le port 8000 en clair.
HOST=0.0.0.0
PORT=8000

# Autoriser sudo/su dans l'exécuteur de commandes (DANGEREUX sur un VPS).
# Laisser "False" sauf besoin explicite.
ALLOW_SUDO_ON_VPS=False

# --- Human-in-the-loop (approbation des outils sensibles) ------------------
# Liste CSV des outils nécessitant une confirmation utilisateur avant exécution.
# Vide = défaut (bash, ssh, domotique, suppressions).
SENSITIVE_TOOLS=
# Auto-approuver les outils sensibles (bypass du gate). "false" (défaut, sécurisé) :
# l'agent doit faire confirmer l'utilisateur. Un canal de confiance (vocal maison)
# peut le passer à "true". Voir aussi les permissions par canal.
AUTO_APPROVE_SENSITIVE=false

# --- Permissions par canal --------------------------------------------------
# Politiques par canal (web/cli/voice/telegram/...) : auto_approve + allow/deny
# d'outils. Voir channel_policies.example.json. Surcharge possible par fichier
# (CHANNEL_POLICIES_PATH) ou directement en JSON via CHANNEL_POLICIES.
CHANNEL_POLICIES_PATH=channel_policies.json
CHANNEL_POLICIES=

# -------------------------------------------------------------------------
# 2. CHEMINS / STOCKAGE
# -------------------------------------------------------------------------
# Chemin du fichier de conversations persistantes.
# Vide = `conversations.json` à la racine du projet.
CONVERSATIONS_PATH=

# Boucle d'auto-amélioration : après une tâche non triviale, l'agent archive un
# court retour d'expérience en mémoire (resservi via le RAG). "true" (défaut) | "false".
SELF_IMPROVE=true

# Acquisition de compétences (façon Voyager) : si une fonction Python PURE et
# réutilisable aurait aidé, l'agent la génère et l'enregistre comme skill permanente
# (validation de sûreté stricte : fonctions pures, sans I/O). "true" (défaut) | "false".
SELF_IMPROVE_SKILLS=true

# Prompt caching : réutilise le préfixe stable (system prompt) pour réduire latence
# et coût. "auto" (défaut : Anthropic uniquement) | "on" (forcé) | "off".
# Sans effet sur l'endpoint custom (qwen3 = prefix caching côté serveur vLLM/SGLang).
PROMPT_CACHE=auto

# Consolidation mémoire : nombre max de retours d'expérience conservés (anti-bloat
# du RAG). Les plus anciens sont élagués au-delà. Défaut 50.
EXPERIENCE_MAX=50

# Routage par difficulté : si défini, les requêtes triviales utilisent ce modèle
# rapide au lieu du modèle de l'agent (les tâches complexes gardent le modèle fort).
# Laisser vide pour désactiver. Ex: FAST_MODEL=gpt-4o-mini
FAST_MODEL=

# Passe critique automatique : un relecteur vérifie la réponse finale et l'agent en
# produit une version corrigée si besoin (qualité accrue, +1-2 appels LLM en fin de
# tâche). "false" (défaut) | "true".
AUTO_CRITIC=false

# Modélisation de l'utilisateur : maintient un profil évolutif (préférences, contexte)
# réinjecté dans le prompt pour personnaliser les réponses. Mis à jour après un échange
# substantiel. "true" (défaut) | "false". Fichier : USER_PROFILE_PATH (def user_profile.md).
USER_MODELING=true
USER_PROFILE_PATH=user_profile.md

# Orchestration par script : l'agent peut écrire UN script Python qui appelle plusieurs
# outils sûrs en une fois (multi-étapes en un seul tour). Validé par AST (pas d'import
# système, eval, open, while), builtins restreints, timeout. "true" (défaut) | "false".
TOOL_SCRIPTS=true
TOOL_SCRIPT_TIMEOUT=30

# Nb max d'outils/sous-agents exécutés EN PARALLÈLE dans un même tour
# (ex: plusieurs query_agent). 1 = exécution séquentielle. Défaut 4.
SWARM_MAX_PARALLEL=4

# --- Garde-fous d'exécution -------------------------------------------------
# Retries sur erreur LLM transitoire (backoff exponentiel). Défaut 2.
LLM_MAX_RETRIES=2
# Réponses tronquées (finish_reason=length) : nb max de continuations auto pour
# recoller une réponse coupée. 0 = désactivé. Défaut 3.
LLM_MAX_CONTINUATIONS=3
# Streaming token-par-token des réponses (latence minimale, surtout vocal). true (défaut).
STREAM_TOKENS=true
# Budget temps mur par run, en secondes (0 = illimité). Utile pour la latence vocale.
SWARM_MAX_SECONDS=0
# Budget tokens cumulés par run (0 = illimité).
SWARM_MAX_TOKENS=0
# Cache des résultats d'outils idempotents (web_search...) : TTL en secondes
# (0 = désactivé) et liste CSV des outils cachés.
TOOL_CACHE_TTL=300
CACHEABLE_TOOLS=web_search,web_scrape,search_memory
# Alerte budget : si le coût cumulé du jour dépasse ce montant (€), une
# notification est envoyée (une fois/jour). 0 = désactivé.
BUDGET_DAILY_LIMIT=0

# --- Mémoire avancée (compaction du contexte long) -------------------------
# Au-delà de MEMORY_MAX_MESSAGES messages dans la vue envoyée au LLM, les plus
# anciens sont résumés en un seul message (les MEMORY_KEEP_RECENT derniers sont
# gardés verbatim). 0 = désactivé. N'affecte pas l'historique persistant.
MEMORY_MAX_MESSAGES=40
MEMORY_KEEP_RECENT=12

# --- Vision (analyse d'images jointes) -------------------------------------
# Décrire les images jointes via un modèle multimodal. "false" (défaut) =
# repli OCR/note. Nécessite un modèle compatible vision.
VISION_ENABLED=false
# Modèle vision (vide = modèle de Jarvis). Ex: gpt-4o, gemini/gemini-2.5-flash.
VISION_MODEL=

# Chemin du fichier de configuration des serveurs MCP.
# Vide = `mcp_servers.json` à la racine du projet.
MCP_CONFIG_PATH=

# --- Observabilité ----------------------------------------------------------
# Niveau de log (DEBUG/INFO/WARNING/ERROR) et dossier des logs (rotation auto).
LOG_LEVEL=INFO
LOG_DIR=logs
# Base SQLite de persistance des runs (inspection/rejeu).
RUNS_DB_PATH=runs.sqlite3

# Dossier de travail actif des agents (explorateur de fichiers, sandbox, outils).
# Vide = sous-dossier workspace/ du projet (confine les agents hors du code source
# et du .env). Mettez un chemin absolu pour pointer ailleurs.
ACTIVE_WORKSPACE_DIR=
# Chemins d'état (vides = racine du projet). Utiles pour tout déporter ailleurs.
CORE_MEMORY_PATH=
CHROMA_DB_PATH=

# --- Déploiement Docker Compose (optionnel) --------------------------------
# Chemin ABSOLU sur l'hôte où persister tout l'état (monté au même chemin dans
# le conteneur, requis pour la sandbox). Ex : /opt/jarvis/data
JARVIS_DATA=

# --- Sandbox d'exécution de code/commandes ---------------------------------
# SANDBOX_MODE : "docker" (défaut, exécution isolée en conteneur jetable)
#                "off"    (exécution locale NON isolée, droits du serveur — risque assumé)
SANDBOX_MODE=docker
# Image de base du conteneur (doit être disponible/pullable).
SANDBOX_DOCKER_IMAGE=python:3.11-slim
SANDBOX_MEM_LIMIT=256m
SANDBOX_CPUS=1.0
SANDBOX_PIDS_LIMIT=128
# Autoriser le réseau DANS la sandbox (pour que le code exécuté accède à internet).
# "false" (défaut, sûr) = réseau coupé. Les outils web_search/web_scrape des agents
# fonctionnent indépendamment de ce réglage (ils tournent côté serveur).
SANDBOX_ALLOW_NETWORK=false

# -------------------------------------------------------------------------
# 3. CLÉS D'API LLM (utilisées par LiteLLM selon les modèles d'agents.yaml)
# -------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GOOGLE_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
# Alibaba Dashscope / Qwen Cloud
DASHSCOPE_API_KEY=
QWEN_API_KEY=

# -------------------------------------------------------------------------
# 4. SERVEURS LLM LOCAUX & ENDPOINTS CUSTOM (OpenAI-compatible)
# -------------------------------------------------------------------------
# Ollama (ex: ollama/llama3)
OLLAMA_API_BASE=
# vLLM / LM Studio / llama.cpp / Open WebUI ...
CUSTOM_LLM_API_BASE=
CUSTOM_LLM_API_KEY=

# -------------------------------------------------------------------------
# 5. GÉNÉRATION D'IMAGES & VIDÉOS
# -------------------------------------------------------------------------
IMAGE_GENERATOR_PROVIDER=
VIDEO_GENERATOR_PROVIDER=
CUSTOM_IMAGE_API_BASE=
CUSTOM_IMAGE_API_KEY=
CUSTOM_VIDEO_API_BASE=
CUSTOM_VIDEO_API_KEY=
FAL_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# -------------------------------------------------------------------------
# 6. EXÉCUTION DISTANTE SSH (optionnel)
# -------------------------------------------------------------------------
SSH_HOST=
SSH_PORT=22
SSH_USERNAME=
# Préférez une clé à un mot de passe.
SSH_PASSWORD=
SSH_KEY_PATH=
SSH_REMOTE_CWD=
# Fichier known_hosts dédié (optionnel ; le known_hosts système est chargé par défaut).
SSH_KNOWN_HOSTS=
# Ajouter automatiquement les clés d'hôte inconnues (DANGEREUX, vulnérable au MITM).
# Laisser "False" : par défaut un hôte inconnu est REFUSÉ. Mettre "True" uniquement
# pour un premier raccordement contrôlé, puis repasser à False.
SSH_AUTO_ADD_HOST_KEYS=False

# -------------------------------------------------------------------------
# 7. DOMOTIQUE HOME ASSISTANT (optionnel)
# -------------------------------------------------------------------------
HA_URL=
HA_TOKEN=

# -------------------------------------------------------------------------
# 8. AGENDA / CALENDRIER (optionnel)
# -------------------------------------------------------------------------
CALDAV_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=
GOOGLE_CALENDAR_ID=
EXTERNAL_ICAL_URL=

# -------------------------------------------------------------------------
# 9. MESSAGERIE & NOTIFICATIONS (optionnel)
# -------------------------------------------------------------------------
# Telegram : bot (canal entrant) + chat_id(s) pour les notifications sortantes.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord / Slack : URL de webhook entrant du salon.
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
# Webhook générique (reçoit un POST JSON {title, message}).
NOTIFY_WEBHOOK_URL=
# Email (SMTP) pour les notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SSL=false
NOTIFY_EMAIL_TO=

# -------------------------------------------------------------------------
# 10. ASSISTANT VOCAL LOCAL (optionnel — voir voice/, requirements-voice.txt)
# -------------------------------------------------------------------------
# Serveur Jarvis à interroger et jeton (si ADMIN_PASSWORD activé).
VOICE_SERVER_URL=http://127.0.0.1:8000
VOICE_CLIENT_ID=voice
VOICE_AUTH_TOKEN=
# STT (faster-whisper) : modèle tiny/base/small/medium/large-v3 ; device cpu/cuda.
VOICE_STT_MODEL=base
VOICE_STT_DEVICE=cpu
VOICE_STT_COMPUTE=int8
VOICE_STT_LANGUAGE=fr
# TTS : "piper" (chemin du modèle .onnx) ou "pyttsx3" (repli système).
VOICE_TTS_ENGINE=piper
VOICE_PIPER_MODEL=
VOICE_PIPER_BIN=piper
# Wake word : "openwakeword" | "porcupine" | "none" (push-to-talk Entrée).
VOICE_WAKE_ENGINE=openwakeword
VOICE_WAKE_WORD=hey jarvis
VOICE_PORCUPINE_KEY=
# VAD (détection de fin de parole) et capture.
VOICE_SILENCE_RMS=0.012
VOICE_SILENCE_MS=800
VOICE_MAX_RECORD_S=15
# Reconnaissance du locuteur (optionnel, nécessite resemblyzer). Enrôler avec :
#   python3 voice_assistant.py enroll <nom> <échantillon.wav>
VOICE_SPEAKERS_DIR=
VOICE_SPEAKER_THRESHOLD=0.70

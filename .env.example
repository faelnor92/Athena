# =========================================================================
# CONFIGURATION DE L'ESSAIM MULTI-AGENT ATHENA v2 (modèle d'exemple)
# -------------------------------------------------------------------------
# Copiez ce fichier en `.env` et renseignez vos valeurs.
# Le fichier `.env` est ignoré par git : n'y mettez JAMAIS de vraie clé
# dans `.env.example`. Aucune valeur réelle ne doit être committée.
# =========================================================================

# -------------------------------------------------------------------------
# 0. IDENTITÉ DE L'APPLICATION
# -------------------------------------------------------------------------
# Nom affiché dans l'interface (titre d'onglet + logo). Change-le pour rebrander
# l'application sans toucher au code. (L'agent orchestrateur reste nommé en interne ;
# pour renommer son affichage, édite son display_name dans agents.yaml.)
APP_NAME=Athena

# -------------------------------------------------------------------------
# 1. SÉCURITÉ & ACCÈS
# -------------------------------------------------------------------------
# Mot de passe d'administration de l'interface web.
# OBLIGATOIRE si le serveur est exposé (bind sur 0.0.0.0) : sans lui, le
# serveur refuse désormais de démarrer en mode exposé.
ADMIN_PASSWORD=
# Multi-utilisateur : dès qu'un compte existe (créé via ⚙️ Réglages → Utilisateurs),
# la connexion par identifiant devient obligatoire. ADMIN_PASSWORD reste un admin
# de secours. Chemin du fichier de comptes (hash PBKDF2, jamais committé) :
USERS_PATH=

# Origines CORS autorisées (séparées par des virgules). Vide = défaut du code.
# Exemple : https://athena.mondomaine.fr,http://localhost:8000
ALLOWED_ORIGINS=

# Interface et port d'écoute du serveur.
# HOST=0.0.0.0 (défaut) = exposé réseau → ADMIN_PASSWORD devient OBLIGATOIRE.
# HOST=127.0.0.1 = accès local uniquement (auth optionnelle).
# En production, exposez via un reverse-proxy HTTPS, pas le port 8000 en clair.
HOST=0.0.0.0
PORT=8000
# Rechargement auto du code (DÉVELOPPEMENT uniquement) : "true" surveille les fichiers
# → CPU élevé EN PERMANENCE. Laisse "false" en déploiement.
RELOAD=false

# Forcer le démarrage exposé (0.0.0.0) SANS mot de passe (TRÈS déconseillé :
# n'activez que derrière un pare-feu/VPN de confiance).
ALLOW_INSECURE_NETWORK=false

# Durée de validité d'une session de connexion, en heures (défaut 7 jours).
SESSION_TTL_HOURS=168

# Anti-brute-force du login : nb max d'échecs par IP dans la fenêtre (secondes).
LOGIN_MAX_FAILS=8
LOGIN_WINDOW_SECONDS=300

# Taille maximale d'un fichier téléversé dans le workspace (Mo).
MAX_UPLOAD_MB=50

# Autoriser sudo/su dans l'exécuteur de commandes (DANGEREUX sur un VPS).
# Laisser "False" sauf besoin explicite.
ALLOW_SUDO_ON_VPS=False

# --- Human-in-the-loop (approbation des outils sensibles) ------------------
# Liste CSV des outils nécessitant une confirmation utilisateur avant exécution.
# Vide = défaut (bash, ssh, domotique, suppressions).
SENSITIVE_TOOLS=
# Auto-approuver les outils sensibles (bypass du gate). "false" (défaut, sécurisé) :
# l'agent doit faire confirmer l'utilisateur. Un canal de confiance (vocal maison)
# peut le passer à "true". Voir aussi les permissions par canal.
AUTO_APPROVE_SENSITIVE=false

# --- Permissions par canal --------------------------------------------------
# Politiques par canal (web/cli/voice/telegram/...) : auto_approve + allow/deny
# d'outils. Voir channel_policies.example.json. Surcharge possible par fichier
# (CHANNEL_POLICIES_PATH) ou directement en JSON via CHANNEL_POLICIES.
CHANNEL_POLICIES_PATH=channel_policies.json
CHANNEL_POLICIES=

# -------------------------------------------------------------------------
# 2. CHEMINS / STOCKAGE
# -------------------------------------------------------------------------
# Chemin du fichier de conversations persistantes.
# Vide = `conversations.json` à la racine du projet.
CONVERSATIONS_PATH=

# Boucle d'auto-amélioration : après une tâche non triviale, l'agent archive un
# court retour d'expérience en mémoire (resservi via le RAG). "true" (défaut) | "false".
SELF_IMPROVE=true

# Acquisition de compétences (façon Voyager) : si une fonction Python PURE et
# réutilisable aurait aidé, l'agent la génère et l'enregistre comme skill permanente
# (validation de sûreté stricte : fonctions pures, sans I/O). "true" (défaut) | "false".
SELF_IMPROVE_SKILLS=true
# Création « propre » : l'induction de compétence ne se déclenche que pour des tâches
# SUBSTANTIELLES — au moins SKILL_MIN_TOOL_CALLS appels d'outils, OU une récupération
# d'erreur, OU une correction. Les tâches triviales ne polluent pas la bibliothèque. Défaut 5.
SKILL_MIN_TOOL_CALLS=5

# Prompt caching : réutilise le préfixe stable (system prompt) pour réduire latence
# et coût. "auto" (défaut : Anthropic uniquement) | "on" (forcé) | "off".
# Sans effet sur l'endpoint custom (qwen3 = prefix caching côté serveur vLLM/SGLang).
PROMPT_CACHE=auto

# Consolidation mémoire : nombre max de retours d'expérience conservés (anti-bloat
# du RAG). Les plus anciens sont élagués au-delà. Défaut 50.
EXPERIENCE_MAX=50

# Routage par difficulté : si défini, les requêtes triviales utilisent ce modèle
# rapide au lieu du modèle de l'agent (les tâches complexes gardent le modèle fort).
# Laisser vide pour désactiver. Ex: FAST_MODEL=gpt-4o-mini
FAST_MODEL=
# Modèle des appels LLM UTILITAIRES internes (jugement/extraction/classification :
# mini-routeur de délégation, juge de relais, induction de compétence, relecture critique).
# Un PETIT modèle suffit et coûte bien moins. Priorité : UTILITY_MODEL > FAST_MODEL > modèle
# de l'agent. Laisser vide → retombe sur FAST_MODEL puis le modèle de l'agent.
UTILITY_MODEL=

# Passe critique automatique : un relecteur vérifie la réponse finale et l'agent en
# produit une version corrigée si besoin (qualité accrue, +1-2 appels LLM en fin de
# tâche). "false" (défaut) | "true".
AUTO_CRITIC=false

# Modélisation de l'utilisateur : maintient un profil évolutif (préférences, contexte)
# réinjecté dans le prompt pour personnaliser les réponses. Mis à jour après un échange
# substantiel. "true" (défaut) | "false". Fichier : USER_PROFILE_PATH (def user_profile.md).
USER_MODELING=true
USER_PROFILE_PATH=user_profile.md

# Orchestration par script : l'agent peut écrire UN script Python qui appelle plusieurs
# outils sûrs en une fois (multi-étapes en un seul tour). Validé par AST (pas d'import
# système, eval, open, while), builtins restreints, timeout. "true" (défaut) | "false".
TOOL_SCRIPTS=true
TOOL_SCRIPT_TIMEOUT=30

# Nb max d'outils/sous-agents exécutés EN PARALLÈLE dans un même tour
# (ex: plusieurs query_agent). 1 = exécution séquentielle. Défaut 4.
SWARM_MAX_PARALLEL=4

# --- Garde-fous d'exécution -------------------------------------------------
# Retries sur erreur LLM transitoire (backoff exponentiel). Défaut 2.
LLM_MAX_RETRIES=2
# Réponses tronquées (finish_reason=length) : nb max de continuations auto pour
# recoller une réponse coupée. 0 = désactivé. Défaut 3.
LLM_MAX_CONTINUATIONS=3
# Streaming token-par-token des réponses (latence minimale, surtout vocal). true (défaut).
STREAM_TOKENS=true
# Nb max de tours (appels LLM) par run du chat avant arrêt. À la limite, un dernier
# appel SANS OUTILS force une réponse finale (synthèse) au lieu d'une erreur. Défaut 20.
SWARM_MAX_TURNS=20
# Disjoncteur anti-répétition : nb max d'exécutions d'un MÊME outil avec les MÊMES
# arguments dans un run (au-delà → rappel « ne te répète pas » sans ré-exécuter).
# Aide les modèles faibles (qwen3) qui rebouclent. 0 = désactivé. Défaut 2.
SWARM_REPEAT_LIMIT=2
# Budget temps mur par run, en secondes (0 = illimité). Utile pour la latence vocale.
SWARM_MAX_SECONDS=0
# Budget tokens cumulés par run (0 = illimité).
SWARM_MAX_TOKENS=0
# Filtrage d'outils par pertinence (ÉCONOMIE DE TOKENS) : n'expose au modèle que les
# schémas d'outils pertinents pour la requête (les ~47 outils pèsent ~5000 tokens/tour).
# Les outils cœur (mémoire, planif, infos, orchestration, skills) restent toujours exposés ;
# seuls les groupes-domaine (code, domotique, web, média, agenda, email…) sont activés par
# mots-clés. true (défaut) | false. TOOL_FILTER_MIN = ne filtre qu'au-delà de N outils.
TOOL_FILTER_ENABLED=true
TOOL_FILTER_MIN=20
# Sélection par pertinence des outils « extra » (skills auto-induites + outils MCP, hors
# groupes) : on n'expose que les N plus pertinents pour la requête s'il y en a plus que N
# (le schéma est masqué, pas l'exécution → zéro perte de capacité). Réglé par TOOL_FILTER_ENABLED.
TOOL_SEMANTIC_TOPN=12
# Cache des résultats d'outils idempotents (web_search...) : TTL en secondes
# (0 = désactivé) et liste CSV des outils cachés.
TOOL_CACHE_TTL=300
CACHEABLE_TOOLS=web_search,web_scrape,search_memory
# Alerte budget : si le coût cumulé du jour dépasse ce montant (€), une
# notification est envoyée (une fois/jour). 0 = désactivé.
BUDGET_DAILY_LIMIT=0

# --- Mémoire avancée (compaction du contexte long) -------------------------
# Au-delà de MEMORY_MAX_MESSAGES messages dans la vue envoyée au LLM, les plus
# anciens sont résumés en un seul message (les MEMORY_KEEP_RECENT derniers sont
# gardés verbatim). 0 = désactivé. N'affecte pas l'historique persistant.
MEMORY_MAX_MESSAGES=40
MEMORY_KEEP_RECENT=12
# Éviction des GROS résultats d'outils déjà exploités : un résultat d'outil dépassant
# EVICT_TOOL_RESULT_MAX caractères, s'il n'est plus dans les EVICT_KEEP_RECENT derniers
# messages, est remplacé par un extrait tête/queue + pointeur (la vue LLM seulement, pas
# l'historique persistant). 0 = désactivé.
EVICT_TOOL_RESULT_MAX=2000
EVICT_KEEP_RECENT=4
# RAG automatique en arrière-plan : top-k des chunks mémoire pré-injectés (une SEULE
# fois par run, pas à chaque tour). 0 = désactive le RAG auto → l'agent utilise l'outil
# search_memory à la demande (mode le plus sobre). Défaut 2.
RAG_BACKGROUND_TOPK=2

# --- Vision (analyse d'images jointes) -------------------------------------
# Décrire les images jointes via un modèle multimodal. "false" (défaut) =
# repli OCR/note. Nécessite un modèle compatible vision.
VISION_ENABLED=false
# Modèle vision (vide = modèle de Athena). Ex: gpt-4o, gemini/gemini-2.5-flash.
VISION_MODEL=

# Chemin du fichier de configuration des serveurs MCP.
# Vide = `mcp_servers.json` à la racine du projet.
MCP_CONFIG_PATH=

# --- Observabilité ----------------------------------------------------------
# Niveau de log (DEBUG/INFO/WARNING/ERROR) et dossier des logs (rotation auto).
LOG_LEVEL=INFO
LOG_DIR=logs
# Base SQLite de persistance des runs (inspection/rejeu).
RUNS_DB_PATH=runs.sqlite3

# Dossier de travail actif des agents (explorateur de fichiers, sandbox, outils).
# Vide = sous-dossier workspace/ du projet (confine les agents hors du code source
# et du .env). Mettez un chemin absolu pour pointer ailleurs.
ACTIVE_WORKSPACE_DIR=
# Chemins d'état (vides = racine du projet). Utiles pour tout déporter ailleurs.
CORE_MEMORY_PATH=
CHROMA_DB_PATH=

# --- Déploiement Docker Compose (optionnel) --------------------------------
# Chemin ABSOLU sur l'hôte où persister tout l'état (monté au même chemin dans
# le conteneur, requis pour la sandbox). Ex : /opt/athena/data
ATHENA_DATA=

# --- Sandbox d'exécution de code/commandes ---------------------------------
# SANDBOX_MODE : "docker" (défaut, exécution isolée en conteneur jetable)
#                "off"    (exécution locale NON isolée, droits du serveur — risque assumé)
SANDBOX_MODE=docker
# Image de base du conteneur (doit être disponible/pullable).
SANDBOX_DOCKER_IMAGE=python:3.11-slim
SANDBOX_MEM_LIMIT=256m
SANDBOX_CPUS=1.0
SANDBOX_PIDS_LIMIT=128
# Autoriser le réseau DANS la sandbox (pour que le code exécuté accède à internet).
# "false" (défaut, sûr) = réseau coupé. Les outils web_search/web_scrape des agents
# fonctionnent indépendamment de ce réglage (ils tournent côté serveur).
SANDBOX_ALLOW_NETWORK=false

# --- Conteneur DEV persistant (console codeur) -----------------------------
# Différent de la sandbox jetable : UN conteneur long-vivant par (utilisateur, projet)
# pour la CONSOLE CODEUR. git, pip/npm et l'état persistent ENTRE les commandes
# (vrai terminal de dev). Réseau activé par défaut (installs). Isolation conservée
# (cap-drop ALL, no-new-privileges, limites). Les fichiers créés restent host-owned.
# DEV_CONTAINER_MODE : "auto" (défaut : si Docker dispo) | "on" | "off"
DEV_CONTAINER_MODE=auto
# Image dev. Si vide, Athena dérive automatiquement SANDBOX_DOCKER_IMAGE + git au build.
# Renseignez une image contenant déjà git+node+toolchains pour gagner du temps.
# SANDBOX_DEV_IMAGE=
# Paquets apt ajoutés à l'image dérivée auto (ex: "nodejs npm build-essential").
# DEV_CONTAINER_APT=
DEV_CONTAINER_NETWORK=bridge
DEV_CONTAINER_MEM=2g
DEV_CONTAINER_CPUS=2.0
DEV_CONTAINER_PIDS=512
# Délai max d'une commande dans le conteneur dev (s) ; et inactivité avant nettoyage (s).
DEV_CONTAINER_EXEC_TIMEOUT=180
DEV_CONTAINER_IDLE=3600

# --- Allowlist d'outils par SESSION (console codeur) ------------------------
# Restreint ce que l'agent codeur peut faire DANS la console (sécurité par session,
# façon OpenClaw), sans modifier sa config d'agent. Listes séparées par des virgules ;
# motif exact ou préfixe* (ex: "transfer_to_*"). `deny` est prioritaire sur `allow`.
# Vide = aucune restriction de session (la config de l'agent + politiques par canal
# s'appliquent toujours). Voir aussi channel_policies.json (allowlist GLOBALE par canal).
# CODER_CONSOLE_ALLOW_TOOLS=read_file,edit_file,write_file,apply_patch,search_code,run_checks,execute_bash_command,git_status,git_diff,git_commit
# CODER_CONSOLE_DENY_TOOLS=create_agent,delete_skill

# --- Délégation (sous-agents) ----------------------------------------------
# Quand un agent confie une sous-tâche à un spécialiste (delegate_to_X) : sous-agent en
# contexte isolé (feuille), outils dangereux retirés, budget borné.
DELEGATE_MAX_DEPTH=1     # profondeur max (1 = parent→enfant ; pas de petit-enfant)
DELEGATE_MAX_TURNS=12    # budget de tours du sous-agent
DELEGATE_TIMEOUT=0       # timeout mur du sous-agent en s (0 = illimité)

# --- Mails : LECTURE + BROUILLONS seulement (jamais d'envoi) ----------------
# L'agent peut lire la boîte (IMAP) et créer des BROUILLONS ; aucun envoi/suppression
# possible (pas de SMTP). Le contenu des mails est traité comme donnée non fiable.
# Gmail : active IMAP + crée un « mot de passe d'application ». Drafts = "[Gmail]/Drafts".
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_SSL=true
# IMAP_USERNAME=toi@gmail.com
# IMAP_PASSWORD=mot_de_passe_application
# EMAIL_FROM=toi@gmail.com
# EMAIL_DRAFTS_FOLDER=Drafts

# -------------------------------------------------------------------------
# 3. CLÉS D'API LLM (utilisées par LiteLLM selon les modèles d'agents.yaml)
# -------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GOOGLE_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
# Alibaba Dashscope / Qwen Cloud
DASHSCOPE_API_KEY=
QWEN_API_KEY=

# -------------------------------------------------------------------------
# 4. SERVEURS LLM LOCAUX & ENDPOINTS CUSTOM (OpenAI-compatible)
# -------------------------------------------------------------------------
# Ollama (ex: ollama/llama3)
OLLAMA_API_BASE=
# vLLM / LM Studio / llama.cpp / Open WebUI ...
CUSTOM_LLM_API_BASE=
CUSTOM_LLM_API_KEY=

# -------------------------------------------------------------------------
# 5. GÉNÉRATION D'IMAGES & VIDÉOS
# -------------------------------------------------------------------------
IMAGE_GENERATOR_PROVIDER=
VIDEO_GENERATOR_PROVIDER=
CUSTOM_IMAGE_API_BASE=
CUSTOM_IMAGE_API_KEY=
CUSTOM_VIDEO_API_BASE=
CUSTOM_VIDEO_API_KEY=
FAL_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# -------------------------------------------------------------------------
# 6. EXÉCUTION DISTANTE SSH (optionnel)
# -------------------------------------------------------------------------
SSH_HOST=
SSH_PORT=22
SSH_USERNAME=
# Préférez une clé à un mot de passe.
SSH_PASSWORD=
SSH_KEY_PATH=
SSH_REMOTE_CWD=
# Fichier known_hosts dédié (optionnel ; le known_hosts système est chargé par défaut).
SSH_KNOWN_HOSTS=
# Ajouter automatiquement les clés d'hôte inconnues (DANGEREUX, vulnérable au MITM).
# Laisser "False" : par défaut un hôte inconnu est REFUSÉ. Mettre "True" uniquement
# pour un premier raccordement contrôlé, puis repasser à False.
SSH_AUTO_ADD_HOST_KEYS=False

# -------------------------------------------------------------------------
# 7. DOMOTIQUE HOME ASSISTANT (optionnel)
# -------------------------------------------------------------------------
HA_URL=
HA_TOKEN=

# -------------------------------------------------------------------------
# 8. AGENDA / CALENDRIER  ⚠️ DÉSORMAIS PAR UTILISATEUR (plus via .env)
# -------------------------------------------------------------------------
# La config agenda (CalDAV / iCal / Google) est maintenant PROPRE À CHAQUE
# UTILISATEUR : chacun branche son calendrier dans ⚙️ Réglages → Agenda.
# Stockée dans user_configs.json (par compte), PAS ici. Ces variables ne sont
# plus lues — laissées en commentaire pour mémoire.
# CALDAV_URL=
# CALDAV_USERNAME=
# CALDAV_PASSWORD=
# GOOGLE_CALENDAR_ID=        # (OAuth) calendrier ciblé ; défaut "primary" = ton agenda principal
# EXTERNAL_ICAL_URL=

# --- OAuth Google (Calendar + Gmail) — identifiants de l'APPLICATION (globaux) ---
# Recommandé pour brancher TON agenda/tes mails Google sans partage ni compte de service.
# 1) Google Cloud Console → API & Services → Identifiants → "ID client OAuth 2.0",
#    type "Application Web". 2) Active les API "Google Calendar" et "Gmail".
# 3) Ajoute l'URI de redirection AUTORISÉE (doit correspondre EXACTEMENT à GOOGLE_OAUTH_REDIRECT_URI).
# ⚠️ HOMELAB : Google REFUSE une URI http:// sur une IP (ex. http://192.168.x.x). Il te faut
#    soit https:// via un domaine/reverse-proxy (Caddy/Let's Encrypt) ou un tunnel (Cloudflare
#    Tunnel), soit faire l'autorisation depuis le navigateur DU serveur via http://localhost:8000.
# Le refresh_token obtenu est stocké PAR UTILISATEUR (gitignoré), pas ici.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# URI de redirection (DOIT être identique à celle déclarée dans Google Cloud) :
# GOOGLE_OAUTH_REDIRECT_URI=https://athena.mondomaine.fr/api/oauth/google/callback

# -------------------------------------------------------------------------
# 9. MESSAGERIE & NOTIFICATIONS (optionnel)
# -------------------------------------------------------------------------
# Telegram : bot (canal entrant) + chat_id(s) pour les notifications sortantes.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord / Slack : URL de webhook entrant du salon.
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
# Webhook générique (reçoit un POST JSON {title, message}).
NOTIFY_WEBHOOK_URL=
# Email (SMTP) pour les notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SSL=false
NOTIFY_EMAIL_TO=

# -------------------------------------------------------------------------
# 10. ASSISTANT VOCAL LOCAL (optionnel — voir voice/, requirements-voice.txt)
# -------------------------------------------------------------------------
# Serveur Athena à interroger et jeton (si ADMIN_PASSWORD activé).
VOICE_SERVER_URL=http://127.0.0.1:8000
VOICE_CLIENT_ID=voice
VOICE_AUTH_TOKEN=
# STT (faster-whisper) : modèle tiny/base/small/medium/large-v3 ; device cpu/cuda.
VOICE_STT_MODEL=base
VOICE_STT_DEVICE=cpu
VOICE_STT_COMPUTE=int8
VOICE_STT_LANGUAGE=fr
# TTS : "piper" (chemin du modèle .onnx) ou "pyttsx3" (repli système).
VOICE_TTS_ENGINE=piper
VOICE_PIPER_MODEL=
VOICE_PIPER_BIN=piper
# Wake word (détection du mot d'activation côté serveur) :
#   "stt" (DÉFAUT) : transcrit une fenêtre glissante et détecte VOICE_WAKE_WORD (n'importe
#        quel mot, ex. « athena ») — aucun modèle requis, mais STT continu (+ de CPU).
#   "openwakeword" : modèle local très efficace, MAIS uniquement des mots PRÉ-ENTRAÎNÉS
#        (alexa, hey_jarvis, hey_mycroft, hey_rhasspy, timer, weather) → PAS « athena ».
#        Pour « athena » en openwakeword : entraîne un modèle custom, ou prends hey_jarvis.
#        Backend ONNX par défaut (compat. Python 3.13) ; voir OWW_INFERENCE_FRAMEWORK.
#   "porcupine" : Picovoice (clé requise). "none" : push-to-talk (touche Entrée).
VOICE_WAKE_ENGINE=stt
VOICE_WAKE_WORD=athena
# Backend openwakeword : "onnx" (défaut, wheels Python 3.13) | "tflite" (Python ≤3.9).
OWW_INFERENCE_FRAMEWORK=onnx
VOICE_PORCUPINE_KEY=
# VAD (détection de fin de parole) et capture.
VOICE_SILENCE_RMS=0.012
VOICE_SILENCE_MS=800
VOICE_MAX_RECORD_S=15
# Reconnaissance du locuteur (optionnel, nécessite resemblyzer). Enrôler avec :
#   python3 voice_assistant.py enroll <nom> <échantillon.wav>
VOICE_SPEAKERS_DIR=
VOICE_SPEAKER_THRESHOLD=0.70

# -------------------------------------------------------------------------
# FIABILITÉ & SÉCURITÉ MESSAGERIE
# -------------------------------------------------------------------------
# Failover de modèle : si le modèle d'un agent échoue (erreur/timeout/quota) après
# les retries, bascule automatiquement sur ces modèles de secours (dans l'ordre).
# Ex: FALLBACK_MODELS=gpt-4o-mini,claude-haiku-4-5  (laisser vide pour désactiver).
FALLBACK_MODELS=

# DM pairing Telegram : seuls les contacts approuvés peuvent dialoguer avec le bot
# (un inconnu reçoit un code à faire approuver). "true" (défaut) | "false".
TELEGRAM_REQUIRE_PAIRING=true

# Routeur de délégation : un mini-appel LLM décide si une demande relève d'un agent
# spécialiste présent (sinon l'orchestrateur répond lui-même). Indépendant de la langue
# et des agents (liste dynamique). Utilise FAST_MODEL si défini. "true" (défaut) | "false".
DELEGATION_ROUTER=true

# Analyse de document long (analyze_document) : nb max de passages analysés.
# Au-delà, échantillonnage régulier couvrant tout le document. Plus haut = plus complet
# mais plus d'appels LLM (plus lent). Défaut 60.
DOC_MAX_CHUNKS=60

# --- Voix expressive (optionnel) -------------------------------------------
# Autorise le LLM à préfixer sa réponse d'une balise d'émotion ([emotion: enjoué]…)
# retirée du texte affiché et passée au TTS expressif.
VOICE_EMOTION_TAGS=false
# Serveur TTS expressif (XTTS, Chatterbox, Qwen3-TTS, OpenAI-compatible…) : si défini
# et VOICE_TTS_ENGINE=http, la voix passe par ce serveur (POST JSON -> WAV).
VOICE_TTS_HTTP_URL=
VOICE_TTS_VOICE=
# VOICE_TTS_API_KEY=   VOICE_TTS_MODEL=tts-1   VOICE_TTS_FORMAT=wav   VOICE_TTS_TIMEOUT=30

# --- Conscience spatiale / follow-me (optionnel) ---------------------------
# Entité Home Assistant dont l'état = la pièce où se trouve l'utilisateur
# (ex. sensor.piece_actuelle). Vide = fonctionnalité désactivée. Voir docs/follow-me.md.
PRESENCE_ENTITY=

# --- Automatisation n8n (« n8n as a tool », optionnel) ---------------------
# Allowlist de workflows que l'agent peut déclencher PAR NOM (outil trigger_workflow,
# marqué sensible). JSON {nom: url de webhook n8n}. Vide = outil inactif.
# Ex: N8N_WORKFLOWS={"creer_devis":"https://n8n.local/webhook/abc"}
N8N_WORKFLOWS=
# N8N_WORKFLOWS_PATH=   N8N_TIMEOUT=30

# --- Mémoire-graphe (relations entre entités, optionnel) -------------------
# Extraction AUTOMATIQUE de triplets (sujet, relation, objet) à chaque memorize_fact
# (1 appel LLM best-effort). "false" (défaut) = uniquement via l'outil remember_relation.
GRAPH_MEMORY_AUTO=false
# GRAPH_MEMORY_PATH=   GRAPH_MEMORY_MAX=5000

# --- SSO / OIDC (OAuth2, optionnel — entreprise) ---------------------------
# Connexion via un fournisseur d'identité (Google, Azure AD, Keycloak…). Désactivé
# tant que les 3 variables ne sont pas définies. Coexiste avec le login mot de passe.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=   (sinon déduit : <base>/api/auth/oidc/callback)
# OIDC_SCOPES=openid email profile
# OIDC_DEFAULT_ROLE=user
# OIDC_ADMIN_EMAILS=   (CSV d'emails promus admin à la 1ère connexion SSO)

# Observabilité LLM optionnelle (OpenInference -> Phoenix). cf. requirements-observability.txt
OPENINFERENCE_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces

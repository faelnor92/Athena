# =========================================================================
# CONFIGURATION DE L'ESSAIM MULTI-AGENT JARVIS v2 (modèle d'exemple)
# -------------------------------------------------------------------------
# Copiez ce fichier en `.env` et renseignez vos valeurs.
# Le fichier `.env` est ignoré par git : n'y mettez JAMAIS de vraie clé
# dans `.env.example`. Aucune valeur réelle ne doit être committée.
# =========================================================================

# -------------------------------------------------------------------------
# 1. SÉCURITÉ & ACCÈS
# -------------------------------------------------------------------------
# Mot de passe d'administration de l'interface web.
# OBLIGATOIRE si le serveur est exposé (bind sur 0.0.0.0) : sans lui, le
# serveur refuse désormais de démarrer en mode exposé.
ADMIN_PASSWORD=

# Origines CORS autorisées (séparées par des virgules). Vide = défaut du code.
# Exemple : https://jarvis.mondomaine.fr,http://localhost:8000
ALLOWED_ORIGINS=

# Autoriser sudo/su dans l'exécuteur de commandes (DANGEREUX sur un VPS).
# Laisser "False" sauf besoin explicite.
ALLOW_SUDO_ON_VPS=False

# -------------------------------------------------------------------------
# 2. CHEMINS / STOCKAGE
# -------------------------------------------------------------------------
# Chemin du fichier de conversations persistantes.
# Vide = `conversations.json` à la racine du projet.
CONVERSATIONS_PATH=

# Dossier de travail actif des agents (sandbox de fichiers).
# Vide = répertoire courant du process.
ACTIVE_WORKSPACE_DIR=

# -------------------------------------------------------------------------
# 3. CLÉS D'API LLM (utilisées par LiteLLM selon les modèles d'agents.yaml)
# -------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GOOGLE_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
# Alibaba Dashscope / Qwen Cloud
DASHSCOPE_API_KEY=
QWEN_API_KEY=

# -------------------------------------------------------------------------
# 4. SERVEURS LLM LOCAUX & ENDPOINTS CUSTOM (OpenAI-compatible)
# -------------------------------------------------------------------------
# Ollama (ex: ollama/llama3)
OLLAMA_API_BASE=
# vLLM / LM Studio / llama.cpp / Open WebUI ...
CUSTOM_LLM_API_BASE=
CUSTOM_LLM_API_KEY=

# -------------------------------------------------------------------------
# 5. GÉNÉRATION D'IMAGES & VIDÉOS
# -------------------------------------------------------------------------
IMAGE_GENERATOR_PROVIDER=
VIDEO_GENERATOR_PROVIDER=
CUSTOM_IMAGE_API_BASE=
CUSTOM_IMAGE_API_KEY=
CUSTOM_VIDEO_API_BASE=
CUSTOM_VIDEO_API_KEY=
FAL_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# -------------------------------------------------------------------------
# 6. EXÉCUTION DISTANTE SSH (optionnel)
# -------------------------------------------------------------------------
SSH_HOST=
SSH_PORT=22
SSH_USERNAME=
# Préférez une clé à un mot de passe.
SSH_PASSWORD=
SSH_KEY_PATH=
SSH_REMOTE_CWD=
# Fichier known_hosts dédié (optionnel ; le known_hosts système est chargé par défaut).
SSH_KNOWN_HOSTS=
# Ajouter automatiquement les clés d'hôte inconnues (DANGEREUX, vulnérable au MITM).
# Laisser "False" : par défaut un hôte inconnu est REFUSÉ. Mettre "True" uniquement
# pour un premier raccordement contrôlé, puis repasser à False.
SSH_AUTO_ADD_HOST_KEYS=False

# -------------------------------------------------------------------------
# 7. DOMOTIQUE HOME ASSISTANT (optionnel)
# -------------------------------------------------------------------------
HA_URL=
HA_TOKEN=

# -------------------------------------------------------------------------
# 8. AGENDA / CALENDRIER (optionnel)
# -------------------------------------------------------------------------
CALDAV_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=
GOOGLE_CALENDAR_ID=
EXTERNAL_ICAL_URL=

# -------------------------------------------------------------------------
# 9. MESSAGERIE BOT (optionnel)
# -------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

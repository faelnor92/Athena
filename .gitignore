# =========================================================================
#  Jarvis v2 — .gitignore
# =========================================================================

# --- Secrets & configuration locale ---------------------------------------
.env
.env.*
!.env.example
# Config MCP : peut contenir des tokens (GitHub, etc.)
mcp_servers.json
# Politiques par canal locales (le modèle .example est versionné)
channel_policies.json

# --- Logs ------------------------------------------------------------------
*.log
server.log
logs/

# --- Données personnelles / état runtime ----------------------------------
conversations.json
conversations_*.json
core_memory.json
core_memory_*.json
agenda.json
lists.json
routines.json
plans.json
graph_memory.json
graph_memory_*.json
users.json
satellites.json
# Compétences générées par les agents à l'exécution (état local, pas du code source).
# Le dossier est conservé via .gitkeep ; forcez l'ajout d'une skill avec: git add -f skills/<x>.py
skills/*.py
!skills/.gitkeep

# Tout le contenu du workspace est volatil / personnel,
# SAUF la configuration de pricing qui est versionnée.
# (on ignore le contenu, pas le dossier, pour pouvoir ré-inclure un fichier)
workspace/*
!workspace/pricing_config.json

# --- Cas d'évaluation locaux (le modèle .example est versionné) ------------
evals/cases.json

# --- Bases vectorielles / SQLite -------------------------------------------
.chroma_db/
chroma/
*.sqlite3

# --- Environnements virtuels Python ----------------------------------------
.venv/
venv/

# --- Caches & artefacts ----------------------------------------------------
__pycache__/
*.py[cod]
*.bak

# --- Outils locaux (Claude Code, IDE) --------------------------------------
.claude/
.idea/
.vscode/

# --- Artefacts de test ------------------------------------------------------
test_video.mp4

# Empreintes vocales enrôlées (données perso)
voice/speakers/*.npy

# Profil utilisateur évolutif (données perso runtime)
user_profile.md
user_profile_*.md

# Config d'agents LOCALE (le dépôt livre agents.default.yaml + agents.example.yaml)
agents.yaml

# Pairage Telegram (contacts approuvés — donnée locale)
telegram_paired.json
user_configs.json

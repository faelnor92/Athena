# =========================================================================
#  Jarvis v2 — .gitignore
# =========================================================================

# --- Secrets & configuration locale ---------------------------------------
.env
.env.*
!.env.example
# Config MCP : peut contenir des tokens (GitHub, etc.)
mcp_servers.json
# Politiques par canal locales (le modèle .example est versionné)
channel_policies.json

# --- Logs ------------------------------------------------------------------
*.log
server.log
logs/

# --- Données personnelles / état runtime ----------------------------------
conversations.json
conversations_*.json
core_memory.json
core_memory_*.json
agenda.json
lists.json
routines.json
plans.json
graph_memory.json
graph_memory_*.json
# Mémoire-graphe migrée en SQLite (par-utilisateur) + artefacts de test
graph_memory*.db
graph_memory*.db-wal
graph_memory*.db-shm
test.db
test_*.db
shared_projects.json
invites.json
users.json

# Serveurs MCP vendorisés en local (ex. tools/mcp-servers/ha-mcp) : on GARDE la source
# avec le projet (auto-suffisant), mais on ignore les parties régénérables/volumineuses.
tools/mcp-servers/**/.venv/
tools/mcp-servers/**/node_modules/
tools/mcp-servers/**/__pycache__/
tools/mcp-servers/**/*.pyc
tools/mcp-servers/**/.git/
satellites.json
# Compétences générées par les agents à l'exécution (état local, pas du code source).
# Le dossier est conservé via .gitkeep ; forcez l'ajout d'une skill avec: git add -f skills/<x>.py
skills/*.py
!skills/.gitkeep

# Tout le contenu du workspace est volatil / personnel,
# SAUF la configuration de pricing qui est versionnée.
# (on ignore le contenu, pas le dossier, pour pouvoir ré-inclure un fichier)
workspace/*
!workspace/pricing_config.json

# --- Cas d'évaluation locaux (le modèle .example est versionné) ------------
evals/cases.json

# --- Bases vectorielles / SQLite -------------------------------------------
.chroma_db/
chroma/
*.sqlite3

# --- Environnements virtuels Python ----------------------------------------
.venv/
venv/

# --- Caches & artefacts ----------------------------------------------------
__pycache__/
*.py[cod]
*.bak

# --- Outils locaux (Claude Code, IDE) --------------------------------------
.claude/
.idea/
.vscode/

# --- Artefacts de test ------------------------------------------------------
test_video.mp4

# Empreintes vocales enrôlées (données perso)
voice/speakers/*.npy

# Profil utilisateur évolutif (données perso runtime)
user_profile.md
user_profile_*.md

# Config d'agents LOCALE (le dépôt livre agents.default.yaml + agents.example.yaml)
agents.yaml

# Pairage Telegram (contacts approuvés — donnée locale)
telegram_paired.json
user_configs.json

# Store d_état partagé (multi-worker) — données runtime
athena_state.sqlite3
athena_state.sqlite3-wal
athena_state.sqlite3-shm
*.migrated

# Projets de code (hors workspace de base)
athena_projects/

# AthenaDesign : données runtime (projets + sandbox d'exécution du code généré)
athenadesign_projects.json
athenadesign_projects/
athenadesign_shared.json
/sandbox/

# Lien symbolique vers une copie externe (clé USB) — ne pas versionner
/Athena-main

# Protos / handoffs de design (référence locale, hors dépôt)
/Athena - Open Space 2.0 (standalone).html
/cldesign.txt
/static/openspace_proto.html

{
  "_comment": "Copiez ce fichier en mcp_servers.json et adaptez. Format compatible Claude Desktop. Le vrai fichier est ignoré par git (peut contenir des tokens).",
  "mcpServers": {
    "home-assistant": {
      "_note": "Serveur MCP Home Assistant (livré dans tools/mcp-servers/ha-mcp), en STDIO → géré par Athena (démarre/redémarre tout seul, pas de Docker). install.sh remplit 'command' avec le chemin absolu du console-script .venv/bin/ha-mcp. Renseigne HOMEASSISTANT_URL + HOMEASSISTANT_TOKEN puis passe disabled à false.",
      "command": "tools/mcp-servers/ha-mcp/.venv/bin/ha-mcp",
      "args": [],
      "env": {
        "HOMEASSISTANT_URL": "http://homeassistant.local:8123",
        "HOMEASSISTANT_TOKEN": "colle-ton-token-longue-duree-ici"
      },
      "disabled": true
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/chemin/explicite/autorise"],
      "disabled": true,
      "_note": "Serveur sensible (FS) : adapte le chemin autorisé puis disabled=false. Non démarré si ADMIN_PASSWORD est vide."
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_xxx"
      },
      "disabled": true
    },
    "exemple_http": {
      "url": "https://mon-serveur-mcp.example.com/mcp",
      "transport": "http"
    },
    "exemple_sse": {
      "url": "https://mon-serveur-mcp.example.com/sse",
      "transport": "sse"
    }
  }
}
